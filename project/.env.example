# Environment variables for Phoenix Rising Window Cleaning (Next.js + Stripe + Resend)
# Copy to `.env.local` for development and add to Vercel project settings for production.
# NEVER commit real keys. All secrets are server-only except NEXT_PUBLIC_* values.

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://phoenixrisingwindowcleaning.com

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (create Products/Prices in the Stripe dashboard, paste IDs here)
STRIPE_PRICE_RESIDENTIAL_STANDARD=price_xxx     # one-time, $189
STRIPE_PRICE_RESIDENTIAL_DELUXE=price_xxx       # one-time, $249
STRIPE_PRICE_RESIDENTIAL_PREMIUM=price_xxx      # one-time, $329
STRIPE_PRICE_MAINTENANCE_MONTHLY=price_xxx      # subscription, monthly
STRIPE_PRICE_MAINTENANCE_QUARTERLY=price_xxx    # subscription, quarterly
# Commercial / High-Rise / Post-construction are quote-based — no fixed Price ID.

# --- Resend (transactional email) ---
RESEND_API_KEY=re_xxx
CONTACT_TO_EMAIL=hello@phoenixrisingwindowcleaning.com

# --- Admin gate ---
ADMIN_PASSWORD=change-me
